{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "registry.schema.json",
  "title": "Blog Daily — Global Registry",
  "description": "Ledger global de stories publicadas + canonical map + counts por grupo/site.",
  "type": "object",
  "required": ["lastUpdated", "storiesPublished", "storiesByGroup", "siteSlugCounts"],
  "properties": {
    "lastUpdated": { "type": "string", "format": "date-time" },
    "storiesPublished": { "type": "integer", "minimum": 0 },
    "storiesByGroup": {
      "type": "object",
      "patternProperties": {
        "^G[1-6]$": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "siteSlugCounts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "lastBatchRunId": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}T\\d{6}Z$" },
    "canonicalMap": {
      "type": "object",
      "description": "storyId -> hub URL absoluta (pra audit cross-reference)",
      "additionalProperties": { "type": "string", "format": "uri" }
    }
  }
}
