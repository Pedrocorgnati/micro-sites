# ============================================================
# Variáveis para Docker Compose (exemplo — commitar este arquivo)
# Copiar para .env.docker e preencher os valores reais
# ============================================================

# App
NODE_ENV=development
PORT=3000

# Site
DOMAIN=localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SITE_SLUG=c01-site-institucional

# Google Analytics 4
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Static Forms
STATIC_FORMS_ENDPOINT=https://api.staticforms.xyz/submit
STATIC_FORMS_ACCESS_KEY=your-access-key-here

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# UptimeRobot (opcional)
UPTIMEROBOT_API_KEY=ur_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UPTIMEROBOT_ALERT_CONTACT_ID=0000000

# Debug
NEXT_PUBLIC_DEBUG_MODE=true
