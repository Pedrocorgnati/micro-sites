{
  "name": "micro-sites",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    ">0.3%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "scripts": {
    "prepare": "husky || true",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset",
    "dev": "next dev",
    "prebuild": "tsx scripts/pre-build.ts",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "build:site": "bash scripts/build-site.sh",
    "generate-og": "tsx scripts/generate-og.ts",
    "build:analyze": "ANALYZE=true next build",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:watch": "vitest --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "validate:articles": "tsx scripts/validate-articles.ts",
    "audit:frontmatter": "tsx scripts/audit-frontmatter.ts",
    "fix:slugs": "tsx scripts/inject-missing-slugs.ts",
    "fix:descriptions": "tsx scripts/inject-missing-descriptions.ts",
    "generate:blog-index": "tsx scripts/generate-blog-index.ts",
    "validate:interlinking": "tsx scripts/validate-interlinking.ts",
    "audit:footprint": "tsx scripts/audit-network-footprint.ts",
    "audit:waves": "tsx scripts/audit-waves.ts",
    "metrics:collect": "tsx scripts/metrics/collect-gsc.ts && tsx scripts/metrics/collect-ga4.ts && tsx scripts/metrics/collect-leads.ts",
    "metrics:aggregate": "tsx scripts/metrics/aggregate.ts",
    "metrics:run": "npm run metrics:collect && npm run metrics:aggregate",
    "validate:copy-uniqueness": "tsx scripts/validate-copy-uniqueness.ts",
    "validate:blog-selectivity": "tsx scripts/validate-blog-selectivity.ts",
    "validate:geo": "tsx scripts/validate-geo-content.ts",
    "validate:all": "npm run validate:articles && npm run validate:interlinking && npm run generate:blog-index && npm run audit:footprint && npm run audit:waves && npm run validate:blog-selectivity && npm run validate:copy-uniqueness && npm run validate:geo",
    "smoke:adsense": "node scripts/smoke-adsense.mjs",
    "audit:analytics": "tsx scripts/audit-analytics-events.ts",
    "audit:contacts": "tsx scripts/audit-contacts-consistency.ts",
    "audit:animations": "tsx scripts/audit-animations.ts",
    "audit:content-uniqueness": "tsx scripts/audit-content-uniqueness.ts",
    "audit:headings": "tsx scripts/audit-headings-hierarchy.ts",
    "audit:cta": "tsx scripts/audit-cta-presence.ts",
    "audit:noscript": "tsx scripts/audit-noscript.ts",
    "ops:dashboard": "tsx scripts/generate-network-dashboard.ts",
    "blog:reconcile": "tsx scripts/blog-inventory-reconcile.ts",
    "validate:rss": "tsx scripts/validate-rss.ts",
    "validate:branding": "tsx scripts/validate-category-branding.ts",
    "generate:favicons": "tsx scripts/generate-category-favicons.ts",
    "reconcile:colors": "tsx scripts/reconcile-accent-colors.ts",
    "data:seed": "tsx scripts/seed-data.ts",
    "data:fix": "tsx scripts/seed-data.ts --fix",
    "data:reset": "tsx scripts/seed-data.ts --force",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:prod:build": "docker build --build-arg SITE_SLUG=${SITE_SLUG:-c01-site-institucional} -t micro-sites .",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium",
    "e2e:report": "playwright show-report",
    "sentry:quota": "tsx scripts/sentry-quota-check.ts",
    "sf:purge": "tsx scripts/sf-purge-24m.ts",
    "synthetic:sf": "tsx scripts/synthetic-static-forms.ts",
    "synthetic:wa": "tsx scripts/synthetic-whatsapp-link.ts",
    "alert:submission-drop": "tsx scripts/alert-submission-drop.ts",
    "alert:calc-completion": "tsx scripts/alert-calc-completion.ts",
    "gsc:indexing-watch": "tsx scripts/gsc-indexing-watch.ts",
    "geo:perplexity": "tsx scripts/geo-monitor-perplexity.ts",
    "geo:chatgpt": "tsx scripts/geo-monitor-chatgpt.ts",
    "geo:google": "tsx scripts/geo-monitor-google-ai-overviews.ts",
    "geo:report": "tsx scripts/geo-aggregate-report.ts",
    "depublish:article": "tsx scripts/depublish-article.ts",
    "dormancy:watch": "tsx scripts/site-dormancy-watch.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/nextjs": "^10.50.0",
    "@types/dompurify": "^3.0.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.0",
    "next": "16.2.3",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "rehype": "^13.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "satori": "^0.26.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
