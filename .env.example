# ============================================
# .env.example - TEMPLATE DE VARIAVEIS DE AMBIENTE
# ============================================
# Copiar para .env e preencher com valores reais
# Este arquivo pode ser versionado (nao contem segredos)
# ============================================

# ============================================
# AMBIENTE
# ============================================
NODE_ENV=development

# ============================================
# APLICACAO
# ============================================
DOMAIN=localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
SITE_SLUG=c01-site-institucional

# ============================================
# GOOGLE ANALYTICS 4
# ============================================
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# ============================================
# FORMULARIOS (Static Forms)
# ============================================
STATIC_FORMS_ENDPOINT=https://api.staticforms.xyz/submit
STATIC_FORMS_ACCESS_KEY=sua-access-key-aqui

# ============================================
# WHATSAPP
# ============================================
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# ============================================
# UPTIMEROBOT
# ============================================
UPTIMEROBOT_API_KEY=sua-api-key-aqui
UPTIMEROBOT_ALERT_CONTACT_ID=123456789

# ============================================
# GOOGLE ADSENSE (ADS-23)
# ============================================
# Publisher ID — formato ca-pub-XXXXXXXXXXXXXXXX (16 digitos).
# 1 conta para os 36 sites. Obtido no painel adsense.google.com.
# Se ausente, ads ficam desabilitados sem quebrar build.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Modelo de personalizacao publicitaria (ADS-38).
# Valores: 'off' | 'npa' | 'personalized'. Default: 'npa' (LGPD-friendly).
# Cat A (saude) sempre forca 'npa' independente desta flag.
NEXT_PUBLIC_ADSENSE_PERSONALIZATION=npa

# ============================================
# AMBIENTE EFETIVO (ADS-23)
# ============================================
# 'production' | 'staging' | 'development'.
# Determina testMode do AdSense:
#   production -> data-adtest="off" (real revenue)
#   qualquer outro -> data-adtest="on" (placeholder Google, zero revenue)
# NAO depende de NODE_ENV (next build forca production em staging tambem).
NEXT_PUBLIC_APP_ENV=development

# ============================================
# INTERNAL / DEVELOPMENT
# ============================================
NEXT_PUBLIC_DEBUG_MODE=true
